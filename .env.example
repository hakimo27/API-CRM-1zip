# ─────────────────────────────────────────────────────────────────────────────
# КаякРент — Production Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string (used by API and drizzle migrations)
DATABASE_URL=postgresql://kayakrent:CHANGE_ME@localhost:5432/kayakrent

# Docker-compose individual DB credentials (used by postgres container)
POSTGRES_DB=kayakrent
POSTGRES_USER=kayakrent
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT Auth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_LONG_RANDOM_STRING_64_CHARS

# Session secret for cookie signing
# Generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_32_CHARS

# ── Public URLs ──────────────────────────────────────────────────────────────
# The public domain the site is accessed from (no trailing slash)
APP_URL=https://kayakrent.ru
ADMIN_URL=https://kayakrent.ru/crm
API_URL=https://kayakrent.ru/api

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (same as APP_URL usually)
CORS_ORIGIN=https://kayakrent.ru

# ── Telegram Bot (optional) ──────────────────────────────────────────────────
# Get from @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Group/forum chat where bot will post
TELEGRAM_MANAGER_GROUP_ID=
TELEGRAM_FORUM_CHAT_ID=
# Secret for webhook signature verification
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=
# Full public URL to your webhook endpoint
TELEGRAM_WEBHOOK_URL=https://kayakrent.ru/api/telegram/webhook

# ── Email / SMTP (optional) ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@kayakrent.ru

# ── Storage ──────────────────────────────────────────────────────────────────
# Local: files are stored in /app/uploads (Docker volume)
STORAGE_DRIVER=local
UPLOADS_DIR=/app/uploads
PUBLIC_UPLOADS_URL=https://kayakrent.ru/uploads

# S3-compatible storage (leave empty to use local storage)
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── App Settings ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
LOG_LEVEL=info
