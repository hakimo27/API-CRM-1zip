# =============================================================================
# Байдабаза — Production Environment Variables
# =============================================================================
# 1. cp .env.example .env
# 2. Заполнить все обязательные переменные (помечены !)
# 3. bash deploy/install.sh
# NEVER commit .env to git.
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
# ! Обязательно: заменить пароли на уникальные строки
POSTGRES_DB=baydabaza
POSTGRES_USER=baydabaza
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# postgres = имя docker-сервиса (НЕ localhost)
DATABASE_URL=postgresql://baydabaza:CHANGE_ME_STRONG_PASSWORD@postgres:5432/baydabaza

# ── JWT / Session ─────────────────────────────────────────────────────────────
# ! Обязательно — сгенерировать командой:
#   openssl rand -hex 64   → для JWT_SECRET и JWT_REFRESH_SECRET
#   openssl rand -hex 32   → для SESSION_SECRET
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_LONG_RANDOM_STRING_64_CHARS
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_32_CHARS

# ── Domain & URLs ─────────────────────────────────────────────────────────────
DOMAIN=your-domain.ru
APP_URL=https://your-domain.ru
ADMIN_URL=https://your-domain.ru/crm
API_URL=https://your-domain.ru/api
CORS_ORIGIN=https://your-domain.ru

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
LOG_LEVEL=info

# ── First Install Flags ───────────────────────────────────────────────────────
# Флаги читает bash deploy/install.sh при первом запуске.
# После установки можно выставить в false для последующих обновлений.

# Применить миграции БД (drizzle push)
APP_RUN_MIGRATIONS=true

# Посеять начальные настройки (контакты, SEO, тексты по умолчанию)
APP_RUN_SEED=true

# Посеять демо-данные (товары, туры, категории, тарифы).
# Включать только для демо-стенда. НЕ включать на production с реальными данными.
APP_RUN_DEMO_SEED=false

# ── Superadmin Bootstrap ──────────────────────────────────────────────────────
# ! Обязательно заполнить для первого запуска.
# Если суперадмин уже существует — шаг пропускается (безопасно повторять).
BOOTSTRAP_SUPERADMIN_CREATE=true
BOOTSTRAP_SUPERADMIN_EMAIL=admin@your-domain.ru
BOOTSTRAP_SUPERADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
BOOTSTRAP_SUPERADMIN_FIRST_NAME=Администратор
BOOTSTRAP_SUPERADMIN_LAST_NAME=
BOOTSTRAP_SUPERADMIN_PHONE=

# ── Redis ─────────────────────────────────────────────────────────────────────
# ! Обязательно в production — установить надёжный пароль
# Сгенерировать: openssl rand -hex 32
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
CACHE_TTL_DEFAULT=300

# ── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_DRIVER=local
UPLOADS_DIR=/app/uploads
PUBLIC_UPLOADS_URL=https://your-domain.ru/uploads

# S3-совместимое хранилище (оставить пустым для local storage)
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# ── Telegram Bot (опционально) ────────────────────────────────────────────────
# Создать бота через @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_MANAGER_GROUP_ID=
TELEGRAM_FORUM_CHAT_ID=
# Сгенерировать: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=https://your-domain.ru/api/telegram/webhook

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Для Mail.ru:
#   SMTP_HOST=smtp.mail.ru
#   SMTP_PORT=465
#   SMTP_SECURE=true          ← ОБЯЗАТЕЛЬНО для порта 465
#   SMTP_USER=your@mail.ru
#   SMTP_PASS=<пароль для внешних приложений> (не пароль от аккаунта!)
#     Создать: mail.ru → Настройки → Пароли для внешних приложений
#
# Для Gmail:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=your@gmail.com
#   SMTP_PASS=<пароль приложения из Google Account>
#
# Для Яндекс.Почты:
#   SMTP_HOST=smtp.yandex.ru
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=your@yandex.ru
#   SMTP_PASS=<пароль приложения>
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@mail.ru
SMTP_PASS=your_external_app_password
SMTP_FROM=your@mail.ru
EMAIL_FROM_NAME=КаякРент

# Email менеджера для получения уведомлений о новых заказах
# Если не указан — уведомления по email не отправляются (только Telegram)
MANAGER_EMAIL=

# ── SEO / Магазин ─────────────────────────────────────────────────────────────
# Название магазина в YML-выгрузке для маркетплейсов
SHOP_NAME=КаякРент
