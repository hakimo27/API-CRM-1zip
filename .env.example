# ─────────────────────────────────────────────────────────────────────────────
# Байдабаза — Production Environment Variables
# 1. cp .env.example .env
# 2. Заполнить все обязательные переменные
# 3. sh deploy/install.sh
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Docker-compose поднимает postgres с этими параметрами
POSTGRES_DB=baydabaza
POSTGRES_USER=baydabaza
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Строка подключения — используется API и drizzle (postgres = имя сервиса в docker-compose)
DATABASE_URL=postgresql://baydabaza:CHANGE_ME_STRONG_PASSWORD@postgres:5432/baydabaza

# ── JWT / Session ─────────────────────────────────────────────────────────────
# Сгенерировать: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_LONG_RANDOM_STRING_64_CHARS
# Сгенерировать: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_32_CHARS

# ── Domain & URLs ─────────────────────────────────────────────────────────────
DOMAIN=your-domain.ru
APP_URL=https://your-domain.ru
ADMIN_URL=https://your-domain.ru/crm
API_URL=https://your-domain.ru/api

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=https://your-domain.ru

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
LOG_LEVEL=info

# ── First Install Flags ───────────────────────────────────────────────────────
# Эти флаги читает deploy/install.sh при первом запуске.
# После установки можно установить в false, чтобы они не повторялись при update.

# Применить миграции БД при установке
APP_RUN_MIGRATIONS=true

# Посеять базовые настройки (контакты, тексты, SEO-дефолты)
APP_RUN_SEED=true

# Посеять демо-данные (туры, продукты, категории) — включать только для демо-стенда
APP_RUN_DEMO_SEED=false

# ── Superadmin Bootstrap ──────────────────────────────────────────────────────
# Если true — install.sh создаст суперадмина с указанными данными (один раз).
# Безопасно: если суперадмин уже существует — шаг пропускается.
BOOTSTRAP_SUPERADMIN_CREATE=true
BOOTSTRAP_SUPERADMIN_EMAIL=admin@your-domain.ru
BOOTSTRAP_SUPERADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
BOOTSTRAP_SUPERADMIN_FIRST_NAME=Администратор
BOOTSTRAP_SUPERADMIN_LAST_NAME=
BOOTSTRAP_SUPERADMIN_PHONE=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_TTL_DEFAULT=300

# ── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_DRIVER=local
UPLOADS_DIR=/app/uploads
PUBLIC_UPLOADS_URL=https://your-domain.ru/uploads

# S3-совместимое хранилище (оставить пустым для использования local storage)
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# ── Telegram Bot (опционально) ────────────────────────────────────────────────
# Создать бота через @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_MANAGER_GROUP_ID=
TELEGRAM_FORUM_CHAT_ID=
# Сгенерировать: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=https://your-domain.ru/api/telegram/webhook

# ── Email / SMTP (опционально) ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@your-domain.ru
